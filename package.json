{
  "name": "liquifier",
  "version": "1.2.0",
  "description": "Liquifier may be used to generate fluid transcription, according to the concepts of Beethovens Wekstatt",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "node --test",
    "test:coverage": "c8 --all --include=index.js --include=src/**/*.js --include=src/**/*.mjs --exclude=node_modules/** --check-coverage --lines 80 --functions 80 --branches 80 --statements 80 node --test",
    "test:coverage:report": "c8 --all --include=index.js --include=src/**/*.js --include=src/**/*.mjs --exclude=node_modules/** --reporter=text --reporter=lcov node --test",
    "lint": "standard 'index.js' 'src/**/*.js' 'src/**/*.mjs'",
    "lint:fix": "standard --fix 'index.js' 'src/**/*.js' 'src/**/*.mjs'"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/BeethovensWerkstatt/liquifier.git"
  },
  "keywords": [
    "MEI",
    "genetic editions",
    "digital humanities",
    "music encoding"
  ],
  "author": "Johannes Kepper",
  "license": "AGPL-3.0-or-later",
  "bugs": {
    "url": "https://github.com/BeethovensWerkstatt/liquifier/issues"
  },
  "homepage": "https://github.com/BeethovensWerkstatt/liquifier#readme",
  "dependencies": {
    "jsdom": "^25.0.1",
    "minimist": "^1.2.8",
    "thulemeier": "file:./thulemeier",
    "verovio": "^6.2.0",
    "xmldom-qsa": "^1.1.3"
  },
  "devDependencies": {
    "c8": "^10.1.3",
    "standard": "^17.1.2"
  }
}
