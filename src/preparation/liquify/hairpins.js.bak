/**
 * Prepares animations for <hairpin> elements (crescendo/diminuendo wedges)
 * between DT (diplomatic transcript) and AT (annotated transcript).
 * 
 * HAIRPIN ELEMENT COMPLEXITY:
 * - Visual elements (no text content) with form attribute: "cres" (crescendo) or "dim" (diminuendo)
 * - Multiple DT correspondence: one AT hairpin can map to multiple DT hairpins (space-separated corresp attribute)
 * - Three different SVG rendering patterns observed:
 *   1. Single 3-point polyline forming wedge (e.g., "27369,945 23976,1422 27369,2115")
 *   2. Two separate 2-point polylines for top/bottom lines (e.g., two parallel lines)
 *   3. Single 2-point polyline for simplified representation (e.g., "708,297 8335,387")
 * 
 * ANIMATION STRATEGY:
 * - Morph polyline points from DT wedge shape to AT simplified line
 * - Handle multi-correspondence by animating to each DT hairpin position
 * - Position animation via group-level <animateTransform> (like dirs.js)
 * - Shape animation via polyline points attribute
 * 
 * KEY TECHNICAL DETAILS:
 * - AT hairpins reference notes via startid/endid attributes (not text content)
 * - DT hairpins use x/y/x2/y2 positioning attributes in MEI
 * - Transform animations work on <g> elements
 * - Polyline point morphing may require normalization (e.g., 2-point → 3-point)
 * 
 * @param {SVGSVGElement} ftSvg - The fluid transcript SVG (output, will be modified)
 * @param {SVGSVGElement} dtSvg - The diplomatic transcript SVG (reference, read-only)
 * @param {Document} atMeiDom - The annotated transcript MEI DOM (source of hairpin elements)
 * @param {object} tools - Object containing:
 *   - getNewPos(atPos, dtPos): Calculate transformed position between systems
 *   - correspMappings: Map of AT element IDs to DT element IDs
 *   - setAnimation(options): Apply animation states to SVG elements
 *   - logger: Debug logging utility
 */
export function liquifyHairpins (ftSvg, dtSvg, atMeiDom, tools) {
  const { getNewPos, correspMappings, setAnimation, logger } = tools

  // Debug: Log some info about what's in the SVGs
  const ftHairpins = ftSvg.querySelectorAll('[data-class*="hairpin"]')
  const dtHairpins = dtSvg.querySelectorAll('[data-class*="hairpin"]')
  logger.info(`[liquifyHairpins] FT SVG has ${ftHairpins.length} hairpin elements`)
  logger.info(`[liquifyHairpins] DT SVG has ${dtHairpins.length} hairpin elements`)
  if (dtHairpins.length > 0) {
    logger.info(`[liquifyHairpins] First DT hairpin data-id: ${dtHairpins[0].getAttribute('data-id')}`)
  }

  // Find all AT <hairpin> elements
  const atHairpins = atMeiDom.querySelectorAll('hairpin')
  logger.debug('[liquifyHairpins] Found ' + atHairpins.length + ' <hairpin> elements in AT')

  atHairpins.forEach((atHairpin) => {
    const atId = atHairpin.getAttribute('xml:id')
    if (!atId) {
      logger.warn('[liquifyHairpins] AT hairpin missing xml:id, skipping')
      return
    }

    // Find AT hairpin in FT SVG
    const atHairpinGroup = ftSvg.querySelector(`[data-id="${atId}"]`)
    if (!atHairpinGroup) {
      logger.warn(`[liquifyHairpins] AT hairpin ${atId} not found in FT SVG, skipping`)
      return
    }

    // Get correspondence to DT hairpin(s)
    const correspAttr = atHairpin.getAttribute('corresp')
    if (!correspAttr) {
      // Editorial hairpin (no DT correspondence) - fade in from supplements
      logger.debug(`[liquifyHairpins] AT hairpin ${atId} has no corresp (editorial), will fade in from supplements`)
      handleEditorialHairpin(atHairpinGroup, setAnimation)
      return
    }

    // Parse corresp: can be space-separated list of DT hairpin IDs
    // Format can be: "#d62701d0f..." or "../path/file.xml#d62701d0f..."
    // Extract just the ID part after the # symbol
    const dtHairpinIds = correspAttr.trim().split(/\s+/).map(id => {
      const hashIndex = id.lastIndexOf('#')
      return hashIndex >= 0 ? id.substring(hashIndex + 1) : id
    })
    logger.debug(`[liquifyHairpins] AT hairpin ${atId} corresponds to ${dtHairpinIds.length} DT hairpin(s): ${dtHairpinIds.join(', ')}`)

    if (dtHairpinIds.length === 1) {
      // Simple 1:1 correspondence
      handleSingleCorrespondence(atHairpinGroup, dtHairpinIds[0], atId, ftSvg, dtSvg, tools)
    } else {
      // Multi-correspondence: multiple DT hairpins map to single AT hairpin
      handleMultiCorrespondence(atHairpinGroup, dtHairpinIds, atId, ftSvg, dtSvg, tools)
    }
  })

  logger.debug('[liquifyHairpins] Hairpin liquification complete')
}

/**
 * Handle editorial hairpins (no DT correspondence) - fade in from supplements state.
 * These hairpins are added by editors and don't exist in the diplomatic transcript.
 */
function handleEditorialHairpin (atHairpinGroup, setAnimation) {
  // Add "supplied" class for styling
  atHairpinGroup.classList.add('supplied')

  // Fade in from supplements state
  setAnimation({
    elements: [atHairpinGroup],
    findings: { display: 'none' },
    diplomatic: { display: 'none' },
    supplements: { display: 'inline', opacity: 1 },
    conjectures: { display: 'inline', opacity: 1 },
    annotated: { display: 'inline', opacity: 1 }
  })
}

/**
 * Handle simple 1:1 correspondence between AT and DT hairpin.
 * Animates position from DT to AT location.
 */
function handleSingleCorrespondence (atHairpinGroup, dtHairpinId, atId, ftSvg, dtSvg, tools) {
  const { getNewPos, setAnimation, logger } = tools

  // Find DT hairpin in DT SVG
  const dtHairpinGroup = dtSvg.querySelector(`[data-id="${dtHairpinId}"]`)
  if (!dtHairpinGroup) {
    logger.warn(`[liquifyHairpins] DT hairpin ${dtHairpinId} not found in DT SVG for AT hairpin ${atId}, skipping animation`)
    return
  }

  // Get AT hairpin position (from bounding box or polyline)
  const atPos = getHairpinPosition(atHairpinGroup)
  if (!atPos) {
    logger.warn(`[liquifyHairpins] Could not determine position for AT hairpin ${atId}`)
    return
  }

  // Get DT hairpin position
  const dtPos = getHairpinPosition(dtHairpinGroup)
  if (!dtPos) {
    logger.warn(`[liquifyHairpins] Could not determine position for DT hairpin ${dtHairpinId}`)
    return
  }

  logger.debug(`[liquifyHairpins] AT hairpin ${atId} at (${atPos.x}, ${atPos.y}), DT hairpin ${dtHairpinId} at (${dtPos.x}, ${dtPos.y})`)

  // Calculate transformed position
  const newPos = getNewPos(atPos, dtPos)
  if (!newPos || isNaN(newPos.x) || isNaN(newPos.y)) {
    logger.warn(`[liquifyHairpins] getNewPos returned invalid position for AT hairpin ${atId}`)
    return
  }

  // Apply position animation
  const translateX = newPos.x - atPos.x
  const translateY = newPos.y - atPos.y

  setAnimation({
    elements: [atHairpinGroup],
    findings: { display: 'inline', transform: `translate(${translateX}px, ${translateY}px)` },
    diplomatic: { display: 'inline', transform: `translate(${translateX}px, ${translateY}px)` },
    supplements: { display: 'inline', transform: 'translate(0px, 0px)' },
    conjectures: { display: 'inline', transform: 'translate(0px, 0px)' },
    annotated: { display: 'inline', transform: 'translate(0px, 0px)' }
  })

  logger.debug(`[liquifyHairpins] Applied animation to AT hairpin ${atId}: translate(${translateX}px, ${translateY}px)`)
}

/**
 * Handle multi-correspondence: multiple DT hairpins map to single AT hairpin.
 * Strategy: animate position to first DT hairpin (similar to multi-correspondence dirs).
 * TODO: Consider animating through all DT positions sequentially?
 */
function handleMultiCorrespondence (atHairpinGroup, dtHairpinIds, atId, ftSvg, dtSvg, tools) {
  const { getNewPos, setAnimation, logger } = tools

  logger.debug(`[liquifyHairpins] Handling multi-correspondence for AT hairpin ${atId} with ${dtHairpinIds.length} DT hairpins`)

  // For now, animate to the first DT hairpin position
  // (Similar to how multi-correspondence dirs work)
  const firstDtHairpinId = dtHairpinIds[0]
  const dtHairpinGroup = dtSvg.querySelector(`[data-id="${firstDtHairpinId}"]`)
  
  if (!dtHairpinGroup) {
    logger.warn(`[liquifyHairpins] First DT hairpin ${firstDtHairpinId} not found in DT SVG for multi-corresp AT hairpin ${atId}`)
    return
  }

  // Get positions
  const atPos = getHairpinPosition(atHairpinGroup)
  const dtPos = getHairpinPosition(dtHairpinGroup)

  if (!atPos || !dtPos) {
    logger.warn(`[liquifyHairpins] Could not determine positions for multi-corresp AT hairpin ${atId}`)
    return
  }

  // Calculate transformed position
  const newPos = getNewPos(atPos, dtPos)
  if (!newPos || isNaN(newPos.x) || isNaN(newPos.y)) {
    logger.warn(`[liquifyHairpins] getNewPos returned invalid position for multi-corresp AT hairpin ${atId}`)
    return
  }

  // Apply position animation
  const translateX = newPos.x - atPos.x
  const translateY = newPos.y - atPos.y

  setAnimation({
    elements: [atHairpinGroup],
    findings: { display: 'inline', transform: `translate(${translateX}px, ${translateY}px)` },
    diplomatic: { display: 'inline', transform: `translate(${translateX}px, ${translateY}px)` },
    supplements: { display: 'inline', transform: 'translate(0px, 0px)' },
    conjectures: { display: 'inline', transform: 'translate(0px, 0px)' },
    annotated: { display: 'inline', transform: 'translate(0px, 0px)' }
  })

  logger.debug(`[liquifyHairpins] Applied multi-corresp animation to AT hairpin ${atId}: translate(${translateX}px, ${translateY}px)`)
}

/**
 * Extract position from hairpin group.
 * Tries bounding box first, then falls back to polyline coordinates.
 * 
 * @param {SVGGElement} hairpinGroup - The hairpin <g> element
 * @returns {{x: number, y: number}|null} - Position or null if not found
 */
function getHairpinPosition (hairpinGroup) {
  // Try bounding box first
  const bbox = hairpinGroup.querySelector('.bounding-box rect, rect')
  if (bbox) {
    const x = parseFloat(bbox.getAttribute('x'))
    const y = parseFloat(bbox.getAttribute('y'))
    if (!isNaN(x) && !isNaN(y)) {
      return { x, y }
    }
  }

  // Fall back to polyline
  const polyline = hairpinGroup.querySelector('polyline')
  if (polyline) {
    const points = polyline.getAttribute('points')
    if (points) {
      // Parse first point from points string (e.g., "708,297 8335,387" → x=708, y=297)
      const firstPoint = points.trim().split(/\s+/)[0]
      const [x, y] = firstPoint.split(',').map(parseFloat)
      if (!isNaN(x) && !isNaN(y)) {
        return { x, y }
      }
    }
  }

  return null
}
